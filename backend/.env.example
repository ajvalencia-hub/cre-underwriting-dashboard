# Copy this file to .env and fill in whichever keys you have. Every key here
# is optional — the market-context feature degrades per-section when a key
# is missing, it won't crash the app. Geocoding (Nominatim + Census), BLS
# unemployment, FHFA home price appreciation, and FEMA flood zone all work
# with NO key at all.

# Census Bureau API (population, median household income)
# Free, instant signup: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BLS API (unemployment rate) — works unauthenticated at low volume.
# Register for a key only if you need higher rate limits:
# https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# BEA API (regional personal income growth)
# Free, instant signup: https://apps.bea.gov/API/signup/
BEA_API_KEY=

# FRED API (mortgage rate, treasury yield — St. Louis Fed)
# Free, instant signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# HUD USER API (Fair Market Rents) — needs a free account + token:
# https://www.huduser.gov/hudapi/public/register?comingfrom=1
HUD_API_TOKEN=

# Anthropic API — NOT free, billed usage. Used as a fallback for ambiguous
# document-type classification, AND as the primary extraction path for
# Offering Memoranda / "other" documents and messy rent-rolls/T-12s that
# deterministic parsing can't handle. Without it: classification still works
# via keyword heuristics; rent-roll/T-12 extraction still works when the file
# is a clean table; OM/"other" extraction produces no fields (clearly noted,
# never silently skipped).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional — defaults to a small fast model, override if you want a different one.
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# Optional — structured extraction is a harder task, defaults to a stronger model.
ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-5

# OpenAI API — NOT free, billed usage. Only used by the Underwriting Agent
# chat when AGENT_PROVIDER=openai below. Without it, the OpenAI path
# reports itself unavailable in the agent UI (same graceful-degrade
# pattern as every other key in this file); the Anthropic path still works.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.1

# Underwriting Agent chat — which provider answers. Both are implemented;
# this picks which one is live. "anthropic" or "openai".
AGENT_PROVIDER=anthropic
ANTHROPIC_AGENT_MODEL=claude-sonnet-5
